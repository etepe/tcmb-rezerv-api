---
// M-004 dashboard-ui — TCMB rezerv takip sayfası (public route).
// tqrlab.com Astro repo'suna yeni route: /tcmb-rezerv-takip (`/yz-model-takip` deseni).
// NOT: Mevcut repoda bir Layout varsa onu kullan; bu dosya tek başına da çalışacak
// şekilde minimal kabuğu içerir. tqrlab.css'i global stiline taşımayı unutma.
import ReserveAreaChart from "../components/reserve/ReserveAreaChart.tsx";
import "../styles/tqrlab.css";

// Worker tabanı. tqrlab repo'sunda `PUBLIC_REZERV_API_BASE` env'i tanımla (bkz. .env.example).
const apiBase = import.meta.env.PUBLIC_REZERV_API_BASE ?? "https://tcmb-rezerv-api.workers.dev";
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TCMB Rezerv Takip · tqrlab</title>
    <meta name="description" content="TCMB uluslararası rezervlerinin canlı izlendiği tqrlab paneli." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="tqr-grid-overlay">
    <main class="wrap">
      <header class="head">
        <h1>TCMB Uluslararası Rezervler</h1>
        <p class="sub">Haftalık brüt rezerv · toplam / döviz / altın · milyar USD</p>
      </header>

      <section class="panel tqr-glow">
        <ReserveAreaChart client:load apiBase={apiBase} start="01-10-2025" />
      </section>

      <footer class="foot">
        <span class="src">Kaynak: TCMB EVDS</span>
        <span class="brand">tqrlab</span>
      </footer>
    </main>

    <style>
      :global(body) {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }
      .wrap {
        position: relative;
        z-index: 1;
        max-width: 1040px;
        margin: 0 auto;
        padding: 2.5rem 1.25rem 1.5rem;
      }
      .head h1 {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: clamp(1.4rem, 2.4vw, 2rem);
        margin: 0 0 0.35rem;
        color: var(--text);
      }
      .head .sub {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--muted);
        margin: 0 0 1.5rem;
      }
      .panel {
        background: var(--panel);
        border: 1px solid var(--grid);
        border-radius: 12px;
        padding: 1rem 0.75rem 0.5rem;
      }
      .foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
      }
      .foot .brand {
        text-transform: lowercase;
        letter-spacing: 0.02em;
      }
    </style>
  </body>
</html>
